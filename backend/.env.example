# 프로덕션(application-prod.yml) 배포 시 필요한 환경변수.
# Spring Boot는 .env 파일을 자동으로 읽지 않으므로, 배포 플랫폼의
# 환경변수 설정(예: Railway/Render 대시보드, systemd EnvironmentFile 등)에
# 아래 값들을 직접 등록해야 합니다.

# 카카오 디벨로퍼스(https://developers.kakao.com)에서 발급받은 REST API 키
KAKAO_REST_API_KEY=

# JWT 서명 비밀키 (32바이트 이상 랜덤 문자열 권장, 예: openssl rand -base64 32)
JWT_SECRET=

# PostgreSQL 연결 정보. PostgreSQL JDBC 드라이버는 URL에 user:password@host 형태를
# 지원하지 않으므로(호스트명으로 오인해 UnknownHostException 발생), URL과 인증정보를 분리해서 설정합니다.
# 예: DATABASE_URL=jdbc:postgresql://host:5432/dbname
DATABASE_URL=
DATABASE_USERNAME=
DATABASE_PASSWORD=

# 프론트엔드 배포 도메인 (콤마로 여러 개 가능)
CORS_ALLOWED_ORIGINS=
