# 프로덕션(application-prod.yml) 배포 시 필요한 환경변수.
# Spring Boot는 .env 파일을 자동으로 읽지 않으므로, 배포 플랫폼의
# 환경변수 설정(예: Railway/Render 대시보드, systemd EnvironmentFile 등)에
# 아래 값들을 직접 등록해야 합니다.

# 카카오 디벨로퍼스(https://developers.kakao.com)에서 발급받은 REST API 키
KAKAO_REST_API_KEY=

# JWT 서명 비밀키 (32바이트 이상 랜덤 문자열 권장, 예: openssl rand -base64 32)
JWT_SECRET=

# PostgreSQL 연결 정보 (예: jdbc:postgresql://host:5432/dbname?user=xxx&password=xxx)
DATABASE_URL=

# 프론트엔드 배포 도메인 (콤마로 여러 개 가능)
CORS_ALLOWED_ORIGINS=
